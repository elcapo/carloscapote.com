---
import Layout from '../../../layouts/Layout.astro';
import ArticlesList from '../../../components/ArticlesList.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const articulos = await getCollection('articulos', ({ data }) => !data.draft);
  const tags = new Set<string>();
  for (const a of articulos) {
    for (const t of a.data.tags) {
      tags.add(t);
    }
  }
  return Array.from(tags).map((tag) => ({
    params: { tag },
  }));
}

const { tag } = Astro.params;
const articulos = (await getCollection('articulos', ({ data }) => !data.draft))
  .filter((a) => a.data.tags.includes(tag!))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout title={`#${tag} — Artículos — Carlos Capote`} description={`Artículos etiquetados con «${tag}».`}>
  <section class="page-head">
    <div class="container">
      <p class="eyebrow"><a href="/articulos">← Archivo</a></p>
      <h1 class="display"><span class="tag-head">{tag}</span></h1>
    </div>
  </section>

  <hr class="rule" />

  <section class="list-section">
    <div class="container">
      <ArticlesList articulos={articulos}
        numbering="asc"
        maxTags={3}
        showDrafts={false} />
    </div>
  </section>
</Layout>

<style>
  .page-head {
    padding-block: clamp(5rem, 11vw, 9rem) clamp(3rem, 7vw, 5rem);
  }
  .page-head h1 {
    margin-top: 1.5rem;
    display: flex;
    align-items: baseline;
    gap: 0.25em;
  }
  .tag-head {
    font-weight: inherit;
    color: var(--color-accent);
  }
  .lede {
    margin-top: 2rem;
    font-size: clamp(1.125rem, 1.75vw, 1.375rem);
    line-height: 1.55;
    max-width: 56ch;
    color: var(--color-secondary);
  }

  .list-section {
    padding-block: clamp(3rem, 6vw, 5rem) clamp(5rem, 11vw, 8rem);
  }
</style>
