---
/**
 * Nota inline al estilo Oliver Wyman: un numero clicable que despliega un
 * pequeno popup con una aclaracion o la ficha de una cita.
 *
 * Uso (en archivos .mdx):
 *
 *   import Note from '../../components/Note.astro';
 *
 *   ...un modelo de "32B"<Note>
 *     **32B** sigue la convencion anglosajona...
 *   </Note> parametros...
 *
 * El numero se asigna automaticamente via contadores CSS, asi que no hace
 * falta pasarle ningun indice. El contador se reinicia en cada `.prose`.
 *
 * Para citas con enlace puedes incluir Markdown dentro del slot, incluyendo
 * enlaces, enfasis, etc.
 *
 * El posicionamiento del popup usa Floating UI (`@floating-ui/dom`), que se
 * encarga de colocarlo debajo o encima del marcador segun el espacio
 * disponible, y de posicionar la flecha correctamente en ambos casos.
 */

interface Props {
  /** Texto accesible del marcador y titulo visible del popup. Por defecto: "Nota". */
  label?: string;
}

const { label = 'Nota' } = Astro.props;
const popupId = `note-${crypto.randomUUID().slice(0, 8)}`;
---

<span class="note">
  <button
    class="note-marker"
    type="button"
    aria-expanded="false"
    aria-controls={popupId}
    aria-label={label}
  ></button>
  <span
    class="note-popup"
    id={popupId}
    role="group"
    aria-label={label}
  >
    <span class="note-arrow"></span>
    <span class="note-popup-title">{label}</span>
    <span class="note-popup-body"><slot /></span>
  </span>
</span>

<style>
  .note {
    position: relative;
    display: inline;
    white-space: nowrap;
  }

  .note-marker {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 1.25rem;
    height: 1.25rem;
    padding: 0 0.3rem;
    margin-left: 0.15rem;
    vertical-align: super;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    line-height: 1;
    color: var(--color-background);
    background: var(--color-accent, var(--color-foreground));
    border: none;
    border-radius: 999px;
    cursor: pointer;
    counter-increment: note-counter;
    transition: transform 0.15s ease, opacity 0.15s ease;
  }
  .note-marker::before {
    content: counter(note-counter);
  }
  .note-marker:hover {
    transform: translateY(-1px);
  }
  .note-marker:focus-visible {
    outline: 2px solid var(--color-accent, var(--color-foreground));
    outline-offset: 2px;
  }
  .note-marker[aria-expanded='true'] {
    opacity: 0.85;
  }
  @media (prefers-reduced-motion: reduce) {
    .note-marker {
      transition: none;
    }
    .note-marker:hover {
      transform: none;
    }
  }

  .note-popup {
    position: absolute;
    z-index: 50;
    display: none;
    width: max-content;
    max-width: min(320px, calc(100vw - 2rem));
    padding: 0.875rem 1rem;
    font-family: var(--font-body, inherit);
    font-size: 0.9375rem;
    font-style: normal;
    line-height: 1.5;
    color: var(--color-foreground);
    background: var(--color-muted);
    border: 1.5px solid color-mix(in srgb,var(--color-accent) 30%,var(--color-border));
    border-radius: 0.5rem;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
    white-space: normal;
    text-align: left;
  }

  .note-arrow {
    position: absolute;
    width: 10px;
    height: 10px;
    background: var(--color-muted);
    border: 1px solid color-mix(in srgb,var(--color-accent) 30%,var(--color-border));
    transform: rotate(45deg);
  }
  /* Oculta los bordes que quedan dentro del popup. Floating UI coloca la
     flecha y el script aplica data-placement en el popup para saber que
     bordes recortar. */
  .note-popup[data-placement^='bottom'] .note-arrow {
    border-bottom: none;
    border-right: none;
  }
  .note-popup[data-placement^='top'] .note-arrow {
    border-top: none;
    border-left: none;
  }

  .note-popup-title {
    display: block;
    padding-bottom: 0.5rem;
    margin-bottom: 0.625rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    border-bottom: 1px solid color-mix(in srgb,var(--color-accent) 30%,var(--color-border));
  }
  .note-popup-body {
    display: block;
  }
  .note-popup :global(p) {
    margin: 0 0 0.5rem;
    max-width: none;
  }
  .note-popup :global(p:last-child) {
    margin-bottom: 0;
  }
  .note-popup :global(a) {
    color: var(--color-foreground);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .note[data-open] .note-popup {
    display: block;
  }
</style>

<script>
  import { computePosition, flip, offset, shift, arrow } from '@floating-ui/dom';

  /** Posiciona el popup y la flecha con Floating UI. */
  async function updatePosition(note: Element) {
    const marker = note.querySelector<HTMLElement>('.note-marker');
    const popup = note.querySelector<HTMLElement>('.note-popup');
    const arrowEl = note.querySelector<HTMLElement>('.note-arrow');
    if (!marker || !popup || !arrowEl) return;

    const { x, y, placement, middlewareData } = await computePosition(marker, popup, {
      placement: 'bottom',
      middleware: [
        offset(8),
        flip({ padding: 8 }),
        shift({ padding: 8 }),
        arrow({ element: arrowEl, padding: 8 }),
      ],
    });

    Object.assign(popup.style, { left: `${x}px`, top: `${y}px` });
    popup.setAttribute('data-placement', placement);

    if (middlewareData.arrow) {
      const { x: ax, y: ay } = middlewareData.arrow;
      const side = placement.split('-')[0] as 'top' | 'bottom';
      const staticSide = side === 'top' ? 'bottom' : 'top';
      Object.assign(arrowEl.style, {
        left: ax != null ? `${ax}px` : '',
        top: ay != null ? `${ay}px` : '',
        [staticSide]: '-5px',
        [side]: '',
      });
    }
  }

  // --- Estado global de cleanup para scroll/resize ---
  let posCleanup: (() => void) | null = null;

  function closeAllNotes() {
    posCleanup?.();
    document.querySelectorAll('.note[data-open]').forEach((n) => {
      n.removeAttribute('data-open');
      const popup = n.querySelector<HTMLElement>('.note-popup');
      if (popup) popup.removeAttribute('data-placement');
      const m = n.querySelector('.note-marker');
      if (m) m.setAttribute('aria-expanded', 'false');
    });
  }

  function openNote(note: Element, marker: Element) {
    note.setAttribute('data-open', '');
    marker.setAttribute('aria-expanded', 'true');

    // Posiciona inmediatamente y re-posiciona en scroll/resize.
    updatePosition(note);

    function onUpdate() {
      if (note.hasAttribute('data-open')) updatePosition(note);
    }
    window.addEventListener('scroll', onUpdate, true);
    window.addEventListener('resize', onUpdate);

    posCleanup = () => {
      window.removeEventListener('scroll', onUpdate, true);
      window.removeEventListener('resize', onUpdate);
      posCleanup = null;
    };
  }

  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    const marker = target.closest('.note-marker');
    if (marker) {
      e.preventDefault();
      const note = marker.closest('.note');
      if (!note) return;
      const wasOpen = note.hasAttribute('data-open');
      closeAllNotes();
      if (!wasOpen) openNote(note, marker);
      return;
    }
    if (!target.closest('.note-popup')) {
      closeAllNotes();
    }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      const open = document.querySelector('.note[data-open]');
      closeAllNotes();
      if (open) {
        const marker = open.querySelector<HTMLButtonElement>('.note-marker');
        marker?.focus();
      }
    }
  });

  document.addEventListener('focusout', (e) => {
    const note = (e.target as HTMLElement).closest('.note[data-open]');
    if (!note) return;
    const next = e.relatedTarget as HTMLElement | null;
    if (next && note.contains(next)) return;
    closeAllNotes();
  });
</script>
