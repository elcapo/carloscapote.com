---
/**
 * Gráfica interactiva para artículos, basada en Chart.js.
 *
 * Uso (en archivos .mdx):
 *
 *   import Chart from '../../components/Chart.astro';
 *
 *   <Chart
 *     title="Memoria (fp16) frente a parámetros del modelo"
 *     xLabel="Parámetros"
 *     yLabel="Memoria (GB)"
 *     xScale="log"   // o "logarithmic"
 *     yScale="log"
 *     data={[
 *       { x: 1_000_000_000,  y: 2 },
 *       { x: 7_000_000_000,  y: 14 },
 *       { x: 32_000_000_000, y: 65 },
 *       { x: 70_000_000_000, y: 140 },
 *     ]}
 *   />
 *
 * `data` admite dos formas: una serie única (array de `{x, y}`) o varias
 * series nombradas (array de `{label, points}`). Los colores y tipografías
 * se toman de las variables CSS de `global.css` y se actualizan al cambiar
 * el esquema de color del sistema.
 */

type Point = { x: number; y: number };
type SinglePoints = Point[];
type MultiSeries = Array<{ label: string; points: Point[] }>;

interface Props {
  /** Tipo de gráfica. Por ahora solo `'line'` está soportado. */
  type?: 'line';
  /** Datos: una serie única o varias series nombradas. */
  data: SinglePoints | MultiSeries;
  /** Etiqueta del eje X. */
  xLabel?: string;
  /** Etiqueta del eje Y. */
  yLabel?: string;
  /** Escala del eje X. `'log'` es alias de `'logarithmic'`. */
  xScale?: 'linear' | 'log' | 'logarithmic';
  /** Escala del eje Y. `'log'` es alias de `'logarithmic'`. */
  yScale?: 'linear' | 'log' | 'logarithmic';
  /** Título, usado como `aria-label` y `<figcaption>`. */
  title?: string;
  /** Alto en píxeles. Por defecto 320. */
  height?: number;
  /** Valores explícitos para los ticks del eje X. Si se omite, Chart.js los elige. */
  xTicks?: number[];
  /** Valores explícitos para los ticks del eje Y. Si se omite, Chart.js los elige. */
  yTicks?: number[];
}

const {
  type = 'line',
  data,
  xLabel,
  yLabel,
  xScale = 'linear',
  yScale = 'linear',
  title,
  height = 320,
  xTicks,
  yTicks,
} = Astro.props;

// Normaliza `data` a formato multi-serie para simplificar el script.
const isMulti = Array.isArray(data) && data.length > 0 && 'points' in (data[0] as object);
const series: MultiSeries = isMulti
  ? (data as MultiSeries)
  : [{ label: yLabel ?? '', points: data as SinglePoints }];

// Chart.js registra la escala como `'logarithmic'`; aceptamos `'log'` como alias.
const normalizeScale = (s: 'linear' | 'log' | 'logarithmic') =>
  s === 'log' ? 'logarithmic' : s;

const config = {
  type,
  series,
  xLabel,
  yLabel,
  xScale: normalizeScale(xScale),
  yScale: normalizeScale(yScale),
  xTicks,
  yTicks,
};

const chartId = `chart-${crypto.randomUUID().slice(0, 8)}`;

// Render SSR a SVG con chartjs-node-canvas. El cliente lo reemplaza por un
// <canvas> interactivo con Chart.js al hidratar. Los colores aquí son los
// valores resueltos del tema claro; al hidratar, el canvas cliente lee las
// CSS vars vivas y puede diferir del esquema oscuro.
const { renderChartSvg } = await import('./chart-ssr');
const ssrSvg = renderChartSvg(config, height);
---

<figure class="chart" style={`--chart-height: ${height}px;`}>
  <div class="chart-canvas-wrap" data-chart-wrap>
    <div class="chart-ssr" set:html={ssrSvg} aria-hidden="true"></div>
    <canvas
      id={chartId}
      data-chart={JSON.stringify(config)}
      role="img"
      aria-label={title ?? 'Gráfica'}></canvas>
  </div>
  {title && <figcaption>{title}</figcaption>}
</figure>

<style>
  .chart {
    margin-block: 2rem;
  }
  .chart-canvas-wrap {
    position: relative;
    width: 100%;
    height: var(--chart-height, 320px);
  }
  .chart-ssr {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
  .chart-ssr :global(svg) {
    display: block;
    width: 100%;
    height: 100%;
  }
  .chart canvas {
    display: block;
    width: 100% !important;
    height: 100% !important;
    position: relative;
    z-index: 1;
  }
  /* Una vez el canvas cliente está listo, ocultamos el SVG SSR. */
  .chart-canvas-wrap[data-hydrated] .chart-ssr {
    display: none;
  }
  .chart-canvas-wrap:not([data-hydrated]) canvas {
    visibility: hidden;
  }
  .chart figcaption {
    margin-top: 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-muted-foreground);
    text-align: center;
  }
</style>

<script>
  import type { Chart as ChartType, ChartConfiguration } from 'chart.js';

  type Point = { x: number; y: number };
  type Series = { label: string; points: Point[] };
  type Config = {
    type: 'line';
    series: Series[];
    xLabel?: string;
    yLabel?: string;
    xScale: 'linear' | 'logarithmic';
    yScale: 'linear' | 'logarithmic';
    xTicks?: number[];
    yTicks?: number[];
  };

  // Lee una variable CSS del :root y la devuelve trim-eada.
  function cssVar(name: string): string {
    return getComputedStyle(document.documentElement).getPropertyValue(name).trim();
  }

  function themeColors() {
    const muted = cssVar('--color-muted-foreground');
    return {
      fg: cssVar('--color-foreground'),
      muted,
      border: `color-mix(in srgb, ${muted} 0%, transparent)`,
      // Grid más visible que el border: usa el muted-foreground con transparencia.
      grid: `color-mix(in srgb, ${muted} 25%, transparent)`,
      accent: cssVar('--color-accent'),
      bg: cssVar('--color-background'),
    };
  }

  // Paleta cíclica para multi-serie. El primero siempre es el acento.
  function seriesColors(n: number): string[] {
    const { accent, fg } = themeColors();
    const palette = [accent, fg, cssVar('--color-secondary') || fg];
    return Array.from({ length: n }, (_, i) => palette[i % palette.length]);
  }

  function buildConfig(cfg: Config): ChartConfiguration {
    const colors = themeColors();
    const sColors = seriesColors(cfg.series.length);
    return {
      type: cfg.type,
      data: {
        datasets: cfg.series.map((s, i) => ({
          label: s.label,
          data: s.points,
          borderColor: sColors[i],
          backgroundColor: sColors[i],
          borderWidth: 2,
          pointRadius: 3,
          pointHoverRadius: 5,
          tension: 0,
        })),
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        animation: { duration: 300 },
        interaction: { mode: 'nearest', intersect: false },
        plugins: {
          legend: {
            display: cfg.series.length > 1,
            labels: { color: colors.fg },
          },
          tooltip: {
            backgroundColor: colors.bg,
            titleColor: colors.fg,
            bodyColor: colors.fg,
            borderColor: colors.border,
            borderWidth: 1,
            callbacks: {
              title: (items) => {
                const p = items[0]?.parsed as { x: number; y: number } | undefined;
                if (!p) return '';
                const x = Number.isFinite(p.x) ? p.x.toLocaleString() : String(p.x);
                return cfg.xLabel ? `${cfg.xLabel}: ${x}` : x;
              },
              label: (ctx) => {
                const p = ctx.parsed as { x: number; y: number };
                const y = Number.isFinite(p.y) ? p.y.toLocaleString() : String(p.y);
                const label = ctx.dataset.label || cfg.yLabel;
                return label ? `${label}: ${y}` : y;
              },
            },
          },
        },
        scales: {
          x: {
            type: cfg.xScale,
            title: cfg.xLabel
              ? { display: true, text: cfg.xLabel, color: colors.muted }
              : { display: false },
            ticks: { color: colors.muted },
            grid: { color: colors.grid },
            border: { color: colors.border },
            ...(cfg.xTicks && cfg.xTicks.length > 0
              ? {
                  min: Math.min(...cfg.xTicks),
                  max: Math.max(...cfg.xTicks),
                  afterBuildTicks: (axis) => {
                    axis.ticks = cfg.xTicks!.map((value) => ({ value }));
                  },
                }
              : {}),
          },
          y: {
            type: cfg.yScale,
            title: cfg.yLabel
              ? { display: true, text: cfg.yLabel, color: colors.muted }
              : { display: false },
            ticks: { color: colors.muted },
            grid: { color: colors.grid },
            border: { color: colors.border },
            ...(cfg.yTicks && cfg.yTicks.length > 0
              ? {
                  min: Math.min(...cfg.yTicks),
                  max: Math.max(...cfg.yTicks),
                  afterBuildTicks: (axis) => {
                    axis.ticks = cfg.yTicks!.map((value) => ({ value }));
                  },
                }
              : {}),
          },
        },
      },
    };
  }

  // Aplica colores actuales a una instancia ya creada (al cambiar el tema).
  function retheme(chart: ChartType, cfg: Config) {
    const fresh = buildConfig(cfg);
    chart.data = fresh.data;
    chart.options = fresh.options!;
    chart.update('none');
  }

  const instances = new WeakMap<HTMLCanvasElement, { chart: ChartType; cfg: Config }>();
  let ChartCtor: typeof import('chart.js').Chart | null = null;

  async function ensureChart() {
    if (!ChartCtor) {
      const mod = await import('chart.js/auto');
      ChartCtor = mod.default;
    }
    return ChartCtor;
  }

  async function initCanvas(canvas: HTMLCanvasElement) {
    if (instances.has(canvas)) return;
    const raw = canvas.dataset.chart;
    if (!raw) return;
    let cfg: Config;
    try {
      cfg = JSON.parse(raw) as Config;
    } catch {
      return;
    }
    const Ctor = await ensureChart();
    const chart = new Ctor(canvas, buildConfig(cfg));
    instances.set(canvas, { chart, cfg });
    // Marca el wrapper como hidratado para que el SVG SSR desaparezca.
    const wrap = canvas.closest('[data-chart-wrap]') as HTMLElement | null;
    if (wrap) wrap.setAttribute('data-hydrated', '');
  }

  function observeAll() {
    const canvases = document.querySelectorAll<HTMLCanvasElement>('canvas[data-chart]');
    if (canvases.length === 0) return;

    const io = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            initCanvas(entry.target as HTMLCanvasElement);
            io.unobserve(entry.target);
          }
        }
      },
      { rootMargin: '200px' },
    );
    canvases.forEach((c) => io.observe(c));
  }

  // Re-tematizado al cambiar el esquema de color.
  function rethemeAll() {
    document.querySelectorAll<HTMLCanvasElement>('canvas[data-chart]').forEach((c) => {
      const entry = instances.get(c);
      if (entry) retheme(entry.chart, entry.cfg);
    });
  }

  // Cambio vía media query del sistema.
  const mq = window.matchMedia('(prefers-color-scheme: dark)');
  mq.addEventListener('change', rethemeAll);

  // Cambio vía toggle manual (atributo data-theme en <html>).
  new MutationObserver(rethemeAll).observe(document.documentElement, {
    attributes: true,
    attributeFilter: ['data-theme'],
  });

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', observeAll, { once: true });
  } else {
    observeAll();
  }
</script>
