---
import type { CollectionEntry } from 'astro:content';

interface Props {
  articulos: CollectionEntry<'articulos'>[];
  headingLevel?: 'h2' | 'h3';
  numbering?: 'asc' | 'desc';
  maxTags?: number;
  showDrafts?: boolean;
}

const {
  articulos,
  headingLevel = 'h2',
  numbering = 'desc',
  maxTags,
  showDrafts = false,
} = Astro.props;

const TitleTag = headingLevel;

const fmt = (d: Date) =>
  d.toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' });

const filtered = articulos.filter((articulo) => ! articulo.data.draft || showDrafts);

const indexFor = (i: number) =>
  numbering === 'desc' ? articulos.length - i : i + 1;
---

<ul class="articles-list">
  {filtered.map((a, i) => {
    const tags = maxTags !== undefined ? a.data.tags.slice(0, maxTags) : a.data.tags;
    return (
      <li class="article-row">
        <a href={`/articulos/${a.id}`} class="article-link">
          <span class="article-num mono">{String(indexFor(i)).padStart(2, '0')}</span>
          <div class="article-content">
            <TitleTag class="article-title">{a.data.title}</TitleTag>
            <p class="article-desc">{a.data.description}</p>
            <div class="article-meta">
              <span class="mono">{fmt(a.data.pubDate)}</span>
              {showDrafts && a.data.draft && <span class="badge">Borrador</span>}
              {tags.map(t => <span class="tag">{t}</span>)}
            </div>
          </div>
          <span class="article-arrow" aria-hidden="true">→</span>
        </a>
      </li>
    );
  })}
</ul>

<style>
  .articles-list {
    list-style: none;
    border-top: 1px solid var(--color-border);
  }

  .article-row {
    border-bottom: 1px solid var(--color-border);
  }

  .article-link {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 1.5rem;
    align-items: start;
    padding-block: 2.25rem;
    color: var(--color-foreground);
    transition: background var(--dur) var(--ease), padding var(--dur) var(--ease);
  }
  .article-link:hover {
    background: var(--color-muted);
    padding-inline: 1.25rem;
  }

  .article-num {
    font-size: 0.875rem;
    color: var(--color-muted-foreground);
    padding-top: 0.5rem;
    min-width: 2.5rem;
  }

  .article-title {
    font-size: clamp(1.5rem, 2.4vw, 2.125rem);
    line-height: 1.15;
    transition: color var(--dur) var(--ease);
  }
  .article-link:hover .article-title { color: var(--color-accent); }

  .article-desc {
    margin-top: 0.75rem;
    color: var(--color-secondary);
    max-width: 68ch;
    font-size: 1.0625rem;
  }

  .article-meta {
    margin-top: 1rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.625rem;
    align-items: center;
    color: var(--color-muted-foreground);
  }

  .tag {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    padding: 0.25rem 0.625rem;
    border: 1px solid var(--color-border);
    text-transform: lowercase;
  }

  .badge {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    padding: 0.25rem 0.625rem;
    background: var(--color-foreground);
    color: var(--color-background);
    text-transform: uppercase;
  }

  .article-arrow {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    color: var(--color-muted-foreground);
    align-self: center;
    transition: transform var(--dur) var(--ease), color var(--dur) var(--ease);
  }
  .article-link:hover .article-arrow {
    color: var(--color-accent);
    transform: translateX(4px);
  }

  @media (max-width: 640px) {
    .article-link {
      grid-template-columns: auto 1fr;
      gap: 1rem;
    }
    .article-arrow { display: none; }
  }
</style>
