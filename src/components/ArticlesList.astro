---
import type { CollectionEntry } from 'astro:content';

type ListEntry =
  | CollectionEntry<'articulos'>
  | CollectionEntry<'apuntes'>;

interface Props {
  articulos: ListEntry[];
  basePath?: string;
  headingLevel?: 'h2' | 'h3';
  numbering?: 'asc' | 'desc';
  maxTags?: number;
  showDrafts?: boolean;
}

const {
  articulos,
  basePath = '/articulos',
  headingLevel = 'h2',
  numbering = 'desc',
  maxTags,
  showDrafts = false,
} = Astro.props;

const TitleTag = headingLevel;

const fmt = (d: Date) =>
  d.toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' });

const filtered = articulos.filter((articulo) => ! articulo.data.draft || showDrafts);

const indexFor = (i: number) =>
  numbering === 'desc' ? articulos.length - i : i + 1;
---

<ul class="articles-list">
  {filtered.map((a, i) => {
    const tags = maxTags !== undefined ? a.data.tags.slice(0, maxTags) : a.data.tags;
    const articleHref = `${basePath}/${a.id}`;
    return (
      <li class="article-row" data-href={articleHref}>
        <span class="article-num mono">{String(indexFor(i)).padStart(2, '0')}</span>
        <div class="article-content">
          <TitleTag class="article-title">
            <a href={articleHref} class="article-title-link">{a.data.title}</a>
          </TitleTag>
          <p class="article-desc">{a.data.description}</p>
          <div class="article-meta">
            <span class="mono">{fmt(a.data.pubDate)}</span>
            {showDrafts && a.data.draft && <span class="badge">Borrador</span>}
            {tags.map(t => <a href={`${basePath}/tags/${encodeURIComponent(t)}`} class="tag">{t}</a>)}
          </div>
        </div>
        <span class="article-arrow" aria-hidden="true">→</span>
      </li>
    );
  })}
</ul>

<script>
  const list = document.querySelector('.articles-list');
  list?.addEventListener('click', (e) => {
    const row = e.target.closest('.article-row');
    if (!row) return;
    if (e.target.closest('a')) return;
    window.location.href = row.dataset.href;
  });
</script>

<style>
  .articles-list {
    list-style: none;
    border-top: 1px solid var(--color-border);
  }

  .article-row {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 1.5rem;
    align-items: start;
    padding-block: 2.25rem;
    border-bottom: 1px solid var(--color-border);
    cursor: pointer;
    transition: background var(--dur) var(--ease), padding var(--dur) var(--ease);
  }
  .article-row:hover {
    background: var(--color-muted);
    padding-inline: 1.25rem;
  }

  .article-num {
    font-size: 0.875rem;
    color: var(--color-muted-foreground);
    padding-top: 0.5rem;
    min-width: 2.5rem;
  }

  .article-title-link {
    color: inherit;
    text-decoration: none;
    transition: color var(--dur) var(--ease);
  }
  .article-title-link:hover {
    color: var(--color-accent);
  }
  .article-row:hover .article-title-link {
    color: var(--color-accent);
  }

  .article-title {
    font-size: clamp(1.5rem, 2.4vw, 2.125rem);
    line-height: 1.15;
  }

  .article-desc {
    margin-top: 0.75rem;
    color: var(--color-secondary);
    max-width: 68ch;
    font-size: 1.0625rem;
  }

  .article-meta {
    margin-top: 1rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.625rem;
    align-items: center;
    color: var(--color-muted-foreground);
  }

  .tag {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    padding: 0.25rem 0.625rem;
    border: 1px solid var(--color-border);
    text-transform: lowercase;
    color: inherit;
    text-decoration: none;
    transition: color var(--dur) var(--ease), border-color var(--dur) var(--ease);
  }
  .tag:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  .badge {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    padding: 0.25rem 0.625rem;
    background: var(--color-foreground);
    color: var(--color-background);
    text-transform: uppercase;
  }

  .article-arrow {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    color: var(--color-muted-foreground);
    align-self: center;
    transition: transform var(--dur) var(--ease), color var(--dur) var(--ease);
  }
  .article-row:hover .article-arrow {
    color: var(--color-accent);
    transform: translateX(4px);
  }

  @media (max-width: 640px) {
    .article-row {
      grid-template-columns: auto 1fr;
      gap: 1rem;
    }
    .article-arrow { display: none; }
  }
</style>
