---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <hr class="rule" />
  <div class="container footer-inner">
    <div class="col col-brand">
      <p class="eyebrow">Carlos Capote</p>
      <p class="tagline">
        Compartir es la tecnología<br/>más antigua.
      </p>
    </div>

    <div class="col">
      <p class="eyebrow">Navegar</p>
      <ul>
        <li><a href="/">Inicio</a></li>
        <li><a href="/articulos">Artículos</a></li>
        <li><a href="/quien-soy">Quién soy</a></li>
      </ul>
    </div>

    <div class="col">
      <p class="eyebrow">Proyectos</p>
      <ul>
        <li><a href="https://bocana.org" rel="noopener">Bocana</a></li>
        <li><a href="/rss.xml">RSS</a></li>
      </ul>
    </div>

    <div class="col">
      <p class="eyebrow">Enlaces</p>
      <ul>
        <li><a href="https://github.com/elcapo/" rel="me noopener">GitHub</a></li>
        <li><a href="https://www.linkedin.com/in/carlos-capote-perez-andreu/" rel="me noopener">LinkedIn</a></li>
        <li><a href="https://twitter.com/soy_capo" rel="me noopener">Twitter</a></li>
      </ul>
    </div>
  </div>
  <div class="container footer-bottom">
    <p class="mono">© {year} Carlos Capote Pérez Andreu · <a href="https://creativecommons.org/licenses/by-sa/4.0/" rel="noopener">CC BY-SA 4.0</a></p>
    <p class="mono">Hecho con <a href="https://astro.build">Astro</a></p>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 4rem;
  }
  .footer-inner {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: var(--grid-gap);
    padding-block: 4rem 3rem;
  }
  .col { grid-column: span 6; }
  .col.col-brand { grid-column: span 12; }

  @media (min-width: 768px) {
    .col { grid-column: span 2; }
    .col.col-brand { grid-column: span 6; }
  }

  .tagline {
    font-family: var(--font-heading);
    font-size: clamp(1.25rem, 2vw, 1.75rem);
    font-weight: 300;
    line-height: 1;
    letter-spacing: -0.04em;
    margin-top: 1.25rem;
    max-width: 22ch;
  }

  ul {
    list-style: none;
    margin-top: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  ul a {
    color: var(--color-foreground);
    font-weight: 500;
  }
  ul a:hover { color: var(--color-accent); }

  .small {
    margin-top: 1rem;
    color: var(--color-muted-foreground);
    font-size: 0.9375rem;
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    padding-block: 1.5rem 2.5rem;
    border-top: 1px solid var(--color-border);
  }
</style>
