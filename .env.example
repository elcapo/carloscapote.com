# Dominio del blog (ej: carloscapote.com)
DOMAIN=carloscapote.com

# Email obligatorio para el registro de Let's Encrypt
LETSENCRYPT_EMAIL=admin@example.com

# Puerto HTTP (por defecto 80)
HTTP_PORT=80

# Puerto HTTPS (por defecto 443)
HTTPS_PORT=443

# Credenciales para el dashboard de Traefik en formato htpasswd
# (vacío = dashboard deshabilitado)
# Generar con: htpasswd -nb admin tu-contraseña
TRAEFIK_DASHBOARD_USERS=

# Subdominio para acceder al dashboard (solo si TRAEFIK_DASHBOARD_USERS no está vacío)
# Por defecto: traefik.${DOMAIN}
TRAEFIK_DASHBOARD_DOMAIN=traefik.${DOMAIN}
